{
  "name": "health-assistant-desktop",
  "version": "0.1.7",
  "private": true,
  "description": "A lightweight tray health assistant for sit and water reminders.",
  "main": "dist/src/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run stop:dev && npm run compile:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "stop:dev": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev-processes.ps1",
    "compile:electron": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json",
    "build": "npm run compile:electron && vite build",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "publish:win": "npm run build && electron-builder --win nsis --publish always",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.codex.health-assistant",
    "productName": "健康助手",
    "publish": [
      {
        "provider": "github",
        "owner": "ydtname",
        "repo": "health-assistant-desktop"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-preload/**/*",
      "assets/icons/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icons",
        "to": "assets/icons"
      }
    ],
    "win": {
      "icon": "assets/icons/health.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron-updater": "^6.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
